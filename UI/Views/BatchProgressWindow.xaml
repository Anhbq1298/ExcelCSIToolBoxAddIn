<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.BatchProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel CSI Toolbox - Progress"
        Width="440"
        Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="24,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F8F8"/>
                                <Setter Property="BorderBrush" Value="#2B579A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Progress Bar Style -->
        <Style x:Key="FlatProgressStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#2B579A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DCDCDC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <Rectangle x:Name="PART_Track" Margin="1"/>
                            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left" Margin="1">
                                <Grid x:Name="ForegroundGrid">
                                    <Rectangle x:Name="Indicator" Fill="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Decorator>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <!-- The Main Container Frame -->
        <Border Background="White" 
                BorderBrush="#D0D0D0" 
                BorderThickness="1" 
                CornerRadius="4" 
                Padding="25">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title -->
                    <RowDefinition Height="*"/>    <!-- Spacing -->
                    <RowDefinition Height="Auto"/> <!-- Progress Bar -->
                    <RowDefinition Height="Auto"/> <!-- Stats -->
                    <RowDefinition Height="25"/>   <!-- Spacing -->
                    <RowDefinition Height="Auto"/> <!-- Button -->
                </Grid.RowDefinitions>

                <!-- Title Section -->
                <TextBlock x:Name="TaskTitleText" 
                           Grid.Row="0"
                           Text="Processing..."
                           FontWeight="SemiBold"
                           FontSize="15"
                           Foreground="#2B579A"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Progress Section -->
                <ProgressBar x:Name="MainProgressBar"
                             Grid.Row="2"
                             Style="{StaticResource FlatProgressStyle}"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Margin="0,0,0,8"/>

                <!-- Stats Section -->
                <Grid Grid.Row="3">
                    <TextBlock x:Name="CountersText"
                               HorizontalAlignment="Left"
                               FontSize="11"
                               Foreground="#666666">
                        <Run Text="Ran: " FontWeight="Bold"/>
                        <Run x:Name="RanCountRun" Text="0"/>
                        <Run Text=" | "/>
                        <Run Text="Skipped: " FontWeight="Bold"/>
                        <Run x:Name="SkippedCountRun" Text="0"/>
                    </TextBlock>

                    <TextBlock x:Name="PercentageText"
                               Grid.Column="1"
                               Text="0% (0/0)"
                               HorizontalAlignment="Right"
                               FontSize="11"
                               Foreground="#666666"/>
                </Grid>

                <!-- Action Section -->
                <Button x:Name="CancelButton"
                        Grid.Row="5"
                        Content="Cancel"
                        Style="{StaticResource ModernButtonStyle}"
                        HorizontalAlignment="Center"
                        Click="CancelButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

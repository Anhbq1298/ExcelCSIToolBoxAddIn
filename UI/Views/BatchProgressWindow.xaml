<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.BatchProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BATCH RUN PROGRESS BAR"
        Width="310"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ShowInTaskbar="False"
        Topmost="True">

    <Grid Margin="16,10,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="BATCH RUN PROGRESS"
                   FontWeight="Bold"
                   FontSize="16"
                   Foreground="#1A1A2E"
                   HorizontalAlignment="Center"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2"
                     x:Name="MainProgressBar"
                     Height="22"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Foreground="#4A76A8"
                     Background="#E0E0E0"
                     BorderBrush="#999999"
                     BorderThickness="1"/>

        <!-- Percentage text -->
        <TextBlock Grid.Row="4"
                   x:Name="PercentageText"
                   Text="0% (0/0)"
                   HorizontalAlignment="Right"
                   FontSize="11"
                   Foreground="#333333"/>

        <!-- Ran / Skipped counters -->
        <TextBlock Grid.Row="6"
                   x:Name="CountersText"
                   HorizontalAlignment="Right"
                   FontSize="11"
                   Foreground="#333333">
            <Run Text="Ran: " FontWeight="Bold"/>
            <Run x:Name="RanCountRun" Text="0"/>
            <Run Text=" | "/>
            <Run Text="Skipped: " FontWeight="Bold"/>
            <Run x:Name="SkippedCountRun" Text="0"/>
        </TextBlock>

        <!-- Cancel button -->
        <Button Grid.Row="8"
                x:Name="CancelButton"
                Content="Cancel"
                Width="80"
                Height="28"
                HorizontalAlignment="Center"
                Click="CancelButton_Click"/>
    </Grid>
</Window>

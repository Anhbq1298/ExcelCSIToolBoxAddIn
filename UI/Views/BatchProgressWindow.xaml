<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.BatchProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel CSI Toolbox - Progress"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI"
        Background="#F5F7FB"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>

        <!-- =========================
             COLOR BRUSHES
             ========================= -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D9E1EC"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1E40AF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569"/>
        <SolidColorBrush x:Key="TrackBrush" Color="#EAF0F7"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BadgeBrush" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="BadgeBorderBrush" Color="#BFDBFE"/>

        <!-- =========================
             BUTTON STYLE
             ========================= -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource PrimaryPressedBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =========================
             PROGRESS BAR STYLE
             NOTE:
             Do NOT override the ControlTemplate here.
             The previous custom template broke the fill behavior.
             ========================= -->
        <Style x:Key="FlatProgressStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18"
          Background="{StaticResource WindowBgBrush}">
        <Border Background="{StaticResource CardBgBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24">

            <Grid MinWidth="460">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Progress"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="TaskTitleText"
                               Margin="0,8,0,0"
                               Text="{Binding TaskTitle, FallbackValue=Processing..., TargetNullValue=Processing...}"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Progress bar -->
                <ProgressBar x:Name="MainProgressBar"
                             Grid.Row="2"
                             Style="{StaticResource FlatProgressStyle}"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue, FallbackValue=0, TargetNullValue=0}"/>

                <!-- Status row -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left status panel -->
                    <Border Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="CountersText"
                                       Grid.ColumnSpan="6"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="Ran: " FontWeight="SemiBold"/>
                                <Run x:Name="RanCountRun" Text="0"/>
                                <Run Text="    "/>
                                <Run Text="Skipped: " FontWeight="SemiBold"/>
                                <Run x:Name="SkippedCountRun" Text="0"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Right percentage badge -->
                    <Border Grid.Column="2"
                            Background="{StaticResource BadgeBrush}"
                            BorderBrush="{StaticResource BadgeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,8"
                            MinWidth="92">
                        <TextBlock x:Name="PercentageText"
                                   Text="{Binding ProgressText, FallbackValue=0% (0/0), TargetNullValue=0% (0/0)}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Button row -->
                <Grid Grid.Row="6">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource ModernButtonStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="CancelButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.LoadCombinationMatrixView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Combination Matrix"
        Height="560"
        Width="980"
        MinHeight="420"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="12">
    <Window.Resources>
        <Style x:Key="MatrixButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C9CED6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#2F3337" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinHeight" Value="26" />
        </Style>

        <Style x:Key="SaveButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MatrixButtonStyle}">
            <Setter Property="Background" Value="#F4F5F7" />
            <Setter Property="BorderBrush" Value="#AEB4BC" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MatrixGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="MinHeight" Value="24" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F7F8FA" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EDF3" />
                    <Setter Property="Foreground" Value="#222222" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MatrixGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderBrush" Value="#ECEFF3" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EDF3" />
                    <Setter Property="BorderBrush" Value="#D8DEE6" />
                    <Setter Property="Foreground" Value="#222222" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NeutralMatrixHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="Background" Value="#F4F5F7" />
            <Setter Property="BorderBrush" Value="#DADDE2" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="LoadCombinationHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1E3A5F" />
            <Setter Property="Background" Value="#EAF2FF" />
            <Setter Property="BorderBrush" Value="#BFD7F5" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Add Row"
                    Width="90"
                    Margin="0,0,8,0"
                    Style="{StaticResource MatrixButtonStyle}"
                    Command="{Binding AddRowCommand}" />
            <Button Content="Delete Row"
                    Width="90"
                    Margin="0,0,8,0"
                    Style="{StaticResource MatrixButtonStyle}"
                    Command="{Binding DeleteSelectedRowsCommand}"
                    CommandParameter="{Binding SelectedItems, ElementName=MatrixGrid}" />
            <Button Content="Save"
                    Width="80"
                    Margin="0,0,8,0"
                    Style="{StaticResource SaveButtonStyle}"
                    Command="{Binding SaveCommand}" />
            <Button Content="Cancel"
                    Width="80"
                    Style="{StaticResource MatrixButtonStyle}"
                    Command="{Binding CancelCommand}" />
        </StackPanel>

        <DataGrid x:Name="MatrixGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  FrozenColumnCount="2"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  HorizontalScrollBarVisibility="Auto"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  RowHeight="24"
                  ColumnHeaderHeight="28"
                  VerticalScrollBarVisibility="Auto"
                  BorderBrush="#DADDE2"
                  BorderThickness="1"
                  Background="#FFFFFF"
                  RowBackground="#FFFFFF"
                  AlternatingRowBackground="#FAFAFA"
                  AlternationCount="2"
                  HorizontalGridLinesBrush="#E6E8EC"
                  VerticalGridLinesBrush="#ECEFF3"
                  RowStyle="{StaticResource MatrixGridRowStyle}"
                  CellStyle="{StaticResource MatrixGridCellStyle}"
                  ColumnHeaderStyle="{StaticResource NeutralMatrixHeaderStyle}" />
    </DockPanel>
</Window>

<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.LoadCombinationMatrixView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Combination Matrix"
        Height="560"
        Width="980"
        MinHeight="420"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="12">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Add Row"
                    Width="90"
                    Margin="0,0,8,0"
                    Command="{Binding AddRowCommand}" />
            <Button Content="Delete Row"
                    Width="90"
                    Margin="0,0,8,0"
                    Command="{Binding DeleteSelectedRowsCommand}"
                    CommandParameter="{Binding SelectedItems, ElementName=MatrixGrid}" />
            <Button Content="Save"
                    Width="80"
                    Margin="0,0,8,0"
                    Command="{Binding SaveCommand}" />
            <Button Content="Cancel"
                    Width="80"
                    Command="{Binding CancelCommand}" />
        </StackPanel>

        <DataGrid x:Name="MatrixGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  FrozenColumnCount="1"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  HorizontalScrollBarVisibility="Auto"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  RowHeight="20"
                  ColumnHeaderHeight="22"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalGridLinesBrush="Black"
                  VerticalGridLinesBrush="Black">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="Blue" />
                    <Setter Property="Background" Value="#F8E2D3" />
                    <Setter Property="BorderBrush" Value="Black" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="4,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>
    </DockPanel>
</Window>

<UserControl x:Class="ExcelCSIToolBoxAddIn.UI.Views.AiAgentChatTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ExcelCSIToolBoxAddIn.UI.ViewModels"
             Loaded="UserControl_Loaded"
             FocusManager.FocusedElement="{Binding ElementName=UserInputBox}">

    <UserControl.Resources>
        <!-- User message bubble style -->
        <Style x:Key="UserBubble" TargetType="Border">
            <Setter Property="Background" Value="#1F6AA5"/>
            <Setter Property="CornerRadius" Value="10,10,2,10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="60,4,4,4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth" Value="480"/>
        </Style>

        <!-- Assistant message bubble style -->
        <Style x:Key="AssistantBubble" TargetType="Border">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="CornerRadius" Value="10,10,10,2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4,4,60,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="480"/>
        </Style>

        <!-- DataTemplate for each chat message -->
        <DataTemplate x:Key="ChatMessageTemplate">
            <Grid>
                <!-- User message: right-aligned blue bubble -->
                <Border Style="{StaticResource UserBubble}"
                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding Content}"
                               Foreground="White"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Assistant message: left-aligned grey bubble -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AssistantBubble}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="🤖 AI Agent"
                                   Foreground="#888888"
                                   FontSize="10"
                                   Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding Content}"
                                   Foreground="#222222"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- Title row -->
            <RowDefinition Height="Auto"/>
            <!-- Chat area + Tool trace side-by-side -->
            <RowDefinition Height="*"/>
            <!-- Input area -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title ──────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="🤖  AI Agent Chat"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#1F6AA5"/>
            <TextBlock Text="Powered by Ollama · Read-only model access"
                       FontSize="10"
                       Foreground="#888888"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ── Main content: chat list + tool trace panel ─────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Chat message list -->
            <Border Grid.Column="0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#FAFAFA">
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <ItemsControl ItemsSource="{Binding Messages}"
                                  ItemTemplate="{StaticResource ChatMessageTemplate}"
                                  Padding="4"/>
                </ScrollViewer>
            </Border>

            <!-- Tool trace / debug panel -->
            <Border Grid.Column="2"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#F9F9F9"
                    Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🔧 Tool Trace"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Foreground="#444444"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Tool Called:"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding LastToolTrace.ToolName, FallbackValue='—'}"
                                   FontSize="10"
                                   Foreground="#1F6AA5"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Arguments:"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding LastToolTrace.ToolArguments, FallbackValue='—'}"
                                   FontSize="10"
                                   Foreground="#333333"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Result:"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding LastToolTrace.ToolMessage, FallbackValue='—'}"
                                   FontSize="10"
                                   Foreground="#333333"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Succeeded:"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding LastToolTrace.ToolSucceeded}"
                                   FontSize="10"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Result JSON:"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"/>
                        <TextBox Text="{Binding LastToolTrace.ToolResultJson, Mode=OneWay, FallbackValue='—'}"
                                 FontSize="9"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Background="#EFEFEF"
                                 BorderThickness="0"
                                 Foreground="#333333"
                                 MinHeight="60"
                                 MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Input area ────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInputBox"
                     Grid.Column="0"
                     Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="36"
                     MaxHeight="80"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Center"
                     Padding="6,4"
                     FontSize="12"
                     BorderBrush="#BBBBBB"
                     BorderThickness="1"
                     IsTabStop="True"
                     Focusable="True"
                     GotKeyboardFocus="UserInputBox_GotKeyboardFocus"
                     PreviewMouseDown="UserInputBox_PreviewMouseDown"/>

            <Button Grid.Column="2"
                    Content="Send"
                    Width="70"
                    Height="36"
                    Command="{Binding SendCommand}"
                    IsDefault="True"
                    FontWeight="SemiBold"
                    Background="#1F6AA5"
                    Foreground="White"
                    BorderBrush="#1B5C90"/>

            <Button Grid.Column="4"
                    Content="Clear"
                    Width="60"
                    Height="36"
                    Command="{Binding ClearCommand}"
                    Background="#E8E8E8"
                    Foreground="#444444"
                    BorderBrush="#CCCCCC"/>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Busy spinner (simple text indicator) -->
            <TextBlock Grid.Column="0"
                       Text="⏳"
                       FontSize="12"
                       Margin="0,0,6,0"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="#666666"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       FontSize="10"
                       Foreground="#AAAAAA"
                       VerticalAlignment="Center"
                       Text="Read-only · Ollama local"/>
        </Grid>
    </Grid>
</UserControl>

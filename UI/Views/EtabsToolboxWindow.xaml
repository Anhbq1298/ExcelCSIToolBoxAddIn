<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.EtabsToolboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ETABS Toolbox"
        Height="400"
        Width="500"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        FontSize="11">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top area -->
        <Border Grid.Row="0"
                Padding="10"
                Margin="0,0,0,10"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Background="#FAFAFA">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Model Name:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="Black"/>

                    <TextBox Grid.Column="1"
                             Margin="12,0,0,0"
                             Text="{Binding ModelDisplayText, Mode=OneWay}"
                             IsReadOnly="True"
                             BorderThickness="1"
                             Background="White"
                             VerticalContentAlignment="Center"
                             Height="26"/>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="Attach"
                            Width="70"
                            Height="30"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Command="{Binding AttachToRunningEtabsCommand}"/>

                    <Button Content="Close"
                            Width="70"
                            Height="30"
                            Padding="10,4"
                            Command="{Binding CloseCurrentEtabsInstanceCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main tabs -->
        <TabControl Grid.Row="1">
            <TabItem Header="Point">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <!-- Col 0: empty indent left -->
                        <ColumnDefinition Width="20"/>

                        <!-- Col 1: label -->
                        <ColumnDefinition Width="*"/>

                        <!-- Col 2: button -->
                        <ColumnDefinition Width="*"/>

                        <!-- Col 3: spacer -->
                        <ColumnDefinition Width="12"/>

                        <!-- Col 4: button -->
                        <ColumnDefinition Width="*"/>

                        <!-- Col 5: empty indent right -->
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="Select Point in Model from Excel Range"
                               VerticalAlignment="Center"
                               Foreground="Black"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0"/>

                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Height="30"
                            Margin="6,0,6,0"
                            Padding="12,4"
                            Content="By UniqueName"
                            Foreground="Blue"
                            Command="{Binding SelectPointsByUniqueNameCommand}"/>

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="Add Point From Range Excel"
                               VerticalAlignment="Center"
                               Foreground="Black"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0"/>

                    <Button Grid.Row="2"
                            Grid.Column="2"
                            Height="30"
                            Margin="6,0,6,0"
                            Padding="12,4"
                            Content="By Cartesian"
                            HorizontalAlignment="Stretch"
                            Foreground="Blue"
                            Command="{Binding AddPointByCartesianCommand}"/>

                    <!-- Row 4 -->
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Text="Extract Selected Point Information"
                               VerticalAlignment="Center"
                               Foreground="Black"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0"/>

                    <Button Grid.Row="4"
                            Grid.Column="2"
                            Height="30"
                            Margin="6,0,6,0"
                            Padding="12,4"
                            Content="Run"
                            HorizontalAlignment="Stretch"
                            Foreground="Blue"
                            Command="{Binding GetSelectedPointsCommand}"/>

                    <!-- Row 6 -->
                    <TextBlock Grid.Row="6"
                               Grid.Column="1"
                               Text="Grouping"
                               VerticalAlignment="Center"
                               Foreground="Black"
                               FontWeight="Bold"
                               Margin="0,0,8,0"/>

                    <Button Grid.Row="6"
                            Grid.Column="2"
                            Height="30"
                            Margin="6,0,6,0"
                            Padding="12,4"
                            Content="Get"
                            HorizontalAlignment="Stretch"
                            Foreground="Blue"/>

                    <Button Grid.Row="6"
                            Grid.Column="4"
                            Height="30"
                            Margin="6,0,6,0"
                            Padding="12,4"
                            Content="Set"
                            HorizontalAlignment="Stretch"
                            Foreground="Blue"/>
                    <Button Grid.Row="2"
                        Grid.Column="4"
                        Height="30"
                        Margin="6,0,6,0"
                        Padding="12,4"
                        Content="By Cartesian"
                        Foreground="Blue"
                        Command="{Binding AddPointsCommand}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Frame">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Margin="4"
                            Padding="8,6"
                            Content="Add Frames"
                            Command="{Binding AddFramesCommand}"/>

                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Margin="4"
                            Padding="8,6"
                            Content="Set Frames"
                            Command="{Binding SetFramesCommand}"/>

                    <Button Grid.Row="1"
                            Grid.Column="0"
                            Margin="4"
                            Padding="8,6"
                            Content="Rename Frames"
                            Command="{Binding RenameFramesCommand}"/>

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Margin="4"
                            Padding="8,6"
                            Content="Get Frames"
                            Command="{Binding GetFramesCommand}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

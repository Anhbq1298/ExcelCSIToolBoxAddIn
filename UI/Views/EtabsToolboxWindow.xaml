<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.EtabsToolboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding ProductTitle, FallbackValue=ETABS Toolbox}"
        Width="800"
        Height="600"
        MinWidth="800"
        MinHeight="600"
        MaxWidth="800"
        MaxHeight="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="11">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F6AA5"/>
            <Setter Property="BorderBrush" Value="#1B5C90"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A7BBE"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#236B9F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#184F7C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#14456B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#B7C4D0"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#A8B5C1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top area -->
        <Border Grid.Row="0"
                Padding="10"
                Margin="0,0,0,10"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Background="#FAFAFA">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding ProductTitle, FallbackValue=ETABS Toolbox}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Content="?"
                            Click="HelpButton_Click"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Model Name:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="Black"
                               Margin="0,0,8,0"/>

                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Text="{Binding ModelDisplayText, Mode=OneWay}"
                             IsReadOnly="True"
                             BorderThickness="1"
                             Background="White"
                             VerticalContentAlignment="Center"
                             FontWeight="Bold"
                             Height="26"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Current Model Unit:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="Black"
                               Margin="0,0,8,0"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding CurrentModelUnitText, Mode=OneWay}"
                             IsReadOnly="True"
                             BorderThickness="1"
                             Background="White"
                             VerticalContentAlignment="Center"
                             FontWeight="Bold"
                             Height="26"/>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="Attach"
                            Width="70"
                            Margin="0,0,8,0"
                            Command="{Binding AttachToRunningCsiCommand}"/>

                    <Button Content="Close"
                            Width="70"
                            Command="{Binding CloseCurrentInstanceCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content frame -->
        <Border Grid.Row="1"
                Padding="8"
                BorderBrush="#CFCFCF"
                BorderThickness="1"
                CornerRadius="4"
                Background="#FFFFFF">

            <TabControl>
                <TabItem Header="Section Property">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <StackPanel Margin="12">
                            <GroupBox Header="Steel Section" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="Ishape" Width="80" Margin="0,0,10,0" Command="{Binding CreateIshapeSectionCommand}" />
                                    <Button Content="Channel" Width="80" Margin="0,0,10,0" Command="{Binding CreateChannelSectionCommand}" />
                                    <Button Content="Angle" Width="80" Margin="0,0,10,0" Command="{Binding CreateAngleSectionCommand}" />
                                    <Button Content="Tube" Width="80" Margin="0,0,10,0" Command="{Binding CreateTubeSectionCommand}" />
                                    <Button Content="Pipe" Width="80" Margin="0,0,10,0" Command="{Binding CreatePipeSectionCommand}" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Concrete Section" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="Rectangle" Width="80" Margin="0,0,10,0" Command="{Binding CreateConcreteRectangleSectionCommand}" />
                                    <Button Content="Circle" Width="80" Margin="0,0,10,0" Command="{Binding CreateConcreteCircleSectionCommand}" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Point">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="Select Point in Model from Excel Range"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="By UniqueName"
                                    Command="{Binding SelectPointsByUniqueNameCommand}"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="Add Point From Range Excel"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="By Cartesian"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding AddPointByCartesianCommand}"/>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Text="Extract Selected Point Information"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Run"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding GetSelectedPointsCommand}"/>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Text="Grouping"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="6"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Get"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding GetPointGroupAssignmentCommand}"/>

                            <Button Grid.Row="6"
                                    Grid.Column="4"
                                    Margin="6,0,6,0"
                                    Content="Set"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding SetPointGroupAssignmentCommand}"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Frame">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2.2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="Get Current Selection Frame UniqueNames"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Run"
                                    Command="{Binding GetSelectedFramesCommand}"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="Select Frame in Model from Excel Range"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="By UniqueName"
                                    Command="{Binding SelectFramesByUniqueNameCommand}"/>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Text="Add Frame From Range Excel"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="By Coor"
                                    Command="{Binding AddFramesByCoordinatesCommand}"/>

                            <Button Grid.Row="4"
                                    Grid.Column="4"
                                    Margin="6,0,6,0"
                                    Content="By Point"
                                    Command="{Binding AddFramesByPointNamesCommand}"/>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Text="Extract Selected Frame Information"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="6"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Run"
                                    Command="{Binding GetSelectedFramesCommand}"/>

                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Text="Change Name"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="8"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Run"
                                    Command="{Binding RenameFramesCommand}"/>

                            <TextBlock Grid.Row="10"
                                       Grid.Column="1"
                                       Text="Frame Section Property"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="10"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Get"
                                    Command="{Binding GetFrameSectionPropertyCommand}"/>

                            <Button Grid.Row="10"
                                    Grid.Column="4"
                                    Margin="6,0,6,0"
                                    Content="Set"
                                    Command="{Binding SetFrameSectionPropertyCommand}"/>

                            <TextBlock Grid.Row="12"
                                       Grid.Column="1"
                                       Text="Frame Group Assignment"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="12"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Get"
                                    Command="{Binding GetFrameGroupAssignmentCommand}"/>

                            <Button Grid.Row="12"
                                    Grid.Column="4"
                                    Margin="6,0,6,0"
                                    Content="Set"
                                    Command="{Binding SetFrameGroupAssignmentCommand}"/>

                            <TextBlock Grid.Row="14"
                                       Grid.Column="1"
                                       Text="Frame Modifier"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>

                            <Button Grid.Row="14"
                                    Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Content="Get"
                                    Command="{Binding GetFrameModifierCommand}"/>

                            <Button Grid.Row="14"
                                    Grid.Column="4"
                                    Margin="6,0,6,0"
                                    Content="Set"
                                    Command="{Binding SetFrameModifierCommand}"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Shell">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <StackPanel Margin="12">
                            <GroupBox Header="Shell Area" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.2*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Create Shell Area From Selected Frames"
                                               VerticalAlignment="Center"
                                               Foreground="Black"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Margin="0,0,8,0"/>

                                    <Button Grid.Column="2"
                                            Content="Create Shell"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding CreateShellAreasFromSelectedFramesCommand}"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="LoadPattern">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <StackPanel Margin="12">
                            <GroupBox Header="Load Patterns" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                                <Grid Height="180">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Existing Patterns in Model" Foreground="Black" Margin="0,0,0,4"/>
                                    <ListView x:Name="LoadPatternList" Grid.Row="1" Grid.Column="0" 
                                              ItemsSource="{Binding LoadPatterns}"
                                              SelectionMode="Extended"
                                              BorderBrush="#CCCCCC" BorderThickness="1"
                                              FontWeight="Normal" Foreground="Black">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Load Pattern Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
                                                <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="150"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Top">
                                        <Button Content="Refresh List" HorizontalAlignment="Stretch" Command="{Binding GetLoadPatternsCommand}" Margin="0,0,0,8"/>
                                        <Button Content="Add From Excel" HorizontalAlignment="Stretch" Command="{Binding AddLoadPatternFromExcelCommand}" Margin="0,0,0,8"/>
                                        <Button Content="Delete Selected" HorizontalAlignment="Stretch" 
                                                Command="{Binding DeleteSelectedLoadPatternsCommand}"
                                                CommandParameter="{Binding ElementName=LoadPatternList, Path=SelectedItems}"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="LoadCombination">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <StackPanel Margin="12">

                            <GroupBox Header="Load Combination" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                                <Grid Height="180">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Existing Combinations in Model" Foreground="Black" Margin="0,0,0,4"/>
                                    <ListView x:Name="LoadCombinationList" Grid.Row="1" Grid.Column="0" 
                                              ItemsSource="{Binding LoadCombinations}"
                                              SelectionMode="Extended"
                                              BorderBrush="#CCCCCC" BorderThickness="1"
                                              FontWeight="Normal" Foreground="Black">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Top">
                                        <Button Content="Refresh List" HorizontalAlignment="Stretch" Command="{Binding GetLoadCombinationsCommand}" Margin="0,0,0,8"/>
                                        <Button Content="Add From Excel" HorizontalAlignment="Stretch" Command="{Binding AddLoadCombinationFromExcelCommand}" Margin="0,0,0,8"/>
                                        <Button Content="Delete Selected" HorizontalAlignment="Stretch" 
                                                Command="{Binding DeleteSelectedLoadCombinationsCommand}"
                                                CommandParameter="{Binding ElementName=LoadCombinationList, Path=SelectedItems}"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>

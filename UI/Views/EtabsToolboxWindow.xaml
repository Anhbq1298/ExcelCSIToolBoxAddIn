<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.EtabsToolboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ETABS Toolbox"
        Height="400"
        Width="500"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        FontSize="11">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                Margin="0,0,0,10"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Background="#FAFAFA">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Model Name:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="Black"/>

                    <TextBox Grid.Column="1"
                             Margin="12,0,0,0"
                             Text="{Binding ModelDisplayText, Mode=OneWay}"
                             IsReadOnly="True"
                             BorderThickness="1"
                             Background="White"
                             VerticalContentAlignment="Center"
                             Height="26"/>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="Attach"
                            Width="70"
                            Height="30"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Command="{Binding AttachToRunningEtabsCommand}"/>

                    <Button Content="Close"
                            Width="70"
                            Height="30"
                            Padding="10,4"
                            Command="{Binding CloseCurrentEtabsInstanceCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Point">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Text="Select Point in Model from Excel Range"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="By UniqueName"
                                Foreground="Blue"
                                Command="{Binding SelectPointsByUniqueNameCommand}"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="Add Point From Range Excel"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="By Cartesian"
                                HorizontalAlignment="Stretch"
                                Foreground="Blue"
                                Command="{Binding AddPointByCartesianCommand}"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="Extract Selected Point Information"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="4"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Run"
                                HorizontalAlignment="Stretch"
                                Foreground="Blue"
                                Command="{Binding GetSelectedPointsCommand}"/>

                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Text="Grouping"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="6"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Get"
                                HorizontalAlignment="Stretch"
                                Foreground="Blue"/>

                        <Button Grid.Row="6"
                                Grid.Column="4"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Set"
                                HorizontalAlignment="Stretch"
                                Foreground="Blue"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Frame">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Text="Select Frame in Model from Excel Range"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="By UniqueName"
                                Foreground="Blue"
                                Command="{Binding SelectFramesByUniqueNameCommand}"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="Add Frame From Range Excel"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="By Coor"
                                Foreground="Blue"
                                Command="{Binding AddFrameByCoordinatesCommand}"/>

                        <Button Grid.Row="2"
                                Grid.Column="4"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="By Point"
                                Foreground="Blue"
                                Command="{Binding AddFrameByPointCommand}"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="Extract Selected Frame Information"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="4"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Run"
                                Foreground="Blue"
                                Command="{Binding GetSelectedFramesCommand}"/>

                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Text="Change Name"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="6"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Run"
                                Foreground="Blue"
                                Command="{Binding RenameFramesCommand}"/>

                        <TextBlock Grid.Row="8"
                                   Grid.Column="1"
                                   Text="Frame Section Property"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="8"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Get"
                                Foreground="Blue"
                                Command="{Binding GetFrameSectionPropertyCommand}"/>

                        <Button Grid.Row="8"
                                Grid.Column="4"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Set"
                                Foreground="Blue"
                                Command="{Binding SetFrameSectionPropertyCommand}"/>

                        <TextBlock Grid.Row="10"
                                   Grid.Column="1"
                                   Text="Frame Group Assignment"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="10"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Get"
                                Foreground="Blue"
                                Command="{Binding GetFrameGroupAssignmentCommand}"/>

                        <Button Grid.Row="10"
                                Grid.Column="4"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Set"
                                Foreground="Blue"
                                Command="{Binding SetFrameGroupAssignmentCommand}"/>

                        <TextBlock Grid.Row="12"
                                   Grid.Column="1"
                                   Text="Frame Modifier"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Row="12"
                                Grid.Column="2"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Get"
                                Foreground="Blue"
                                Command="{Binding GetFrameModifierCommand}"/>

                        <Button Grid.Row="12"
                                Grid.Column="4"
                                Height="30"
                                Margin="6,0,6,0"
                                Padding="12,4"
                                Content="Set"
                                Foreground="Blue"
                                Command="{Binding SetFrameModifierCommand}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
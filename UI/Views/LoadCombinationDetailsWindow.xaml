<Window x:Class="ExcelCSIToolBoxAddIn.UI.Views.LoadCombinationDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Define Combination of Load Case Results" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F0F0">
    <Grid Margin="10">
        <ListView ItemsSource="{Binding}" BorderBrush="#CCCCCC" BorderThickness="1"
                  FontWeight="Normal" Foreground="Black">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Load Case Name" DisplayMemberBinding="{Binding LoadCaseName}" Width="150"/>
                    <GridViewColumn Header="Load Case Type" DisplayMemberBinding="{Binding LoadCaseType}" Width="150"/>
                    <GridViewColumn Header="Mode" DisplayMemberBinding="{Binding Mode}" Width="60"/>
                    <GridViewColumn Header="Scale Factor" DisplayMemberBinding="{Binding ScaleFactor}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>

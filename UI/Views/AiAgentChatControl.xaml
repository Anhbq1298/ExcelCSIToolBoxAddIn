<UserControl x:Class="ExcelCSIToolBoxAddIn.UI.Views.AiAgentChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI"
             FontSize="12"
             Background="#F8FBFD">
    <UserControl.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#202A33"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#667888"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#1F6AA5"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#18527F"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SoftBlueBrush" Color="#EAF5FC"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#C9DDEA"/>
        <SolidColorBrush x:Key="ConversationBrush" Color="#FAFDFF"/>
        <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#F0F6FB"/>
        <SolidColorBrush x:Key="UserBubbleBrush" Color="#236EA8"/>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2A7BBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#B7C4D0"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#A8B5C1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Foreground" Value="#2E3A44"/>
            <Setter Property="Background" Value="#EAF1F6"/>
            <Setter Property="BorderBrush" Value="#D7E5EF"/>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftBlueBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#DAE9F4"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12,10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="MHT AI Assistant"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentModelName, StringFormat=Model: {0}}"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           Margin="0,2,0,8"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel>
                    <Border Style="{StaticResource BadgeStyle}">
                        <TextBlock Text="{Binding Sap2000ConnectionStatus, StringFormat=SAP2000: {0}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource BadgeStyle}">
                        <TextBlock Text="{Binding EtabsConnectionStatus, StringFormat=ETABS: {0}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource ConversationBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="8">
            <ScrollViewer x:Name="ConversationScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Border x:Name="Bubble"
                                        Background="{StaticResource AssistantBubbleBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10,8"
                                        MaxWidth="330"
                                        HorizontalAlignment="Left">
                                    <StackPanel>
                                        <TextBlock x:Name="RoleText"
                                                   Text="{Binding Role}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="MessageText"
                                                   Text="{Binding Content}"
                                                   Foreground="{StaticResource InkBrush}"
                                                   TextWrapping="Wrap"
                                                   LineStackingStrategy="BlockLineHeight"
                                                   LineHeight="17"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubbleBrush}"/>
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource UserBubbleBrush}"/>
                                    <Setter TargetName="RoleText" Property="Foreground" Value="White"/>
                                    <Setter TargetName="MessageText" Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsTemporary}" Value="True">
                                    <Setter TargetName="Bubble" Property="Opacity" Value="0.78"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="10"
                Margin="0,10,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="74"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputTextBox"
                         Grid.Column="0"
                         MinHeight="72"
                         MaxHeight="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="White"
                         Foreground="{StaticResource InkBrush}"
                         Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Button Content="Send"
                            Command="{Binding SendCommand}"
                            Style="{StaticResource RoundedButtonStyle}"/>
                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Style="{StaticResource QuietButtonStyle}"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusText}"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis"
                   Margin="2,0,2,0"/>
    </Grid>
</UserControl>
